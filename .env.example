# AI Operational Memory — Environment Configuration
# Copy to .env and adjust values for your environment

# Application
APP_ENV=development
APP_VERSION=0.1.0
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Storage
DB_PATH=data/operational_memory.db

# Scanner
SCAN_INTERVAL_SECONDS=300
MAX_SCAN_HISTORY=100

# Telegram Delivery (optional — all features disabled by default)
# Set TELEGRAM_ENABLED=true and supply BOT_TOKEN + CHAT_ID to activate.
# NEVER commit real tokens. Use environment variables or a secrets manager.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_DAILY_DIGEST_ENABLED=true
TELEGRAM_CRITICAL_ALERTS_ENABLED=true
# Quiet hours in UTC (HH:MM). No immediate alerts sent in this window.
# Overnight window: 22:00–08:00 = quiet from 10pm to 8am UTC
TELEGRAM_QUIET_HOURS_START=22:00
TELEGRAM_QUIET_HOURS_END=08:00
